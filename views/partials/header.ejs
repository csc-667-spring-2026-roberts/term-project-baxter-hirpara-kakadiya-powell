<!-- /partials/header.ejs - Header partial -->
<header>
	<!-- Flash messages -->
	<% if (locals.success) { %>
	<div class="flash-message success">
		<%= locals.success %>
	</div>
	<% } %>
	
	<% if (locals.error) { %>
	<div class="flash-message error">
		<%= locals.error %>
	</div>
	<% } %>

	<!-- lhs: list active games -->
	<div class="dropdown">
		<button class="dropdown-toggle">My Games</button>
		<div class="dropdown-menu">
			<% if (locals.games && locals.games.length > 0) { %>
			<% locals.games.forEach(function(e) { %>
			<a href="/game/<%= e.id %>"><%= e.name %></a>
			<% }); %>
			<% } else { %>
			<span>No active games</span>
			<% } %>
		</div>
	</div>

	<!-- middle button: find game -->
	<button id="find-game-button">Find Game</button>
	<!-- dialog modal for find-game-button -->
	<%- include('find-game-dialog') %>

	<!-- rhs: profile dropdown -->
	<div class="dropdown">
		<button class="dropdown-toggle">Profile</button>
		<div class="dropdown-menu">
			<% if (locals.user) { %>
			<span><%= locals.user.username %></span>
			<span><%= locals.user.email %></span>
			<span>$<%= locals.user.balance.toFixed(2) %></span>
			<form action="/logout" method="POST">
				<button type="submit">Logout</button>
			</form>
			<% } else { %>
			<span>Anonymous</span>
			<a href="/login">Log in</a>
			<% } %>
		</div>
	</div>
</header>

