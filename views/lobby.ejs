<%# lobby.ejs - Lobby page %>
<%- contentFor('body') %>

<h2>Lobby</h2>

<div id="lobby-buttons">
	<% if (locals.user) { %>
	<button id="create-game-button">Create Game</button>
	<%- include('partials/create-game-dialog') %>
	<% } %>
</div>

<div id="lobby-filters">
	<div class="segment">
		<input type="radio" name="blinds" id="b-all" value="" checked>
		<label for="b-all">All</label>
		<% const blindsSeen = new Set(); %>
		<% Object.values(locals.gameConfigs).forEach(cfg => { %>
		<% const key = '$' + cfg.smallBlind + '/$' + cfg.bigBlind; %>
		<% if (!blindsSeen.has(key)) { blindsSeen.add(key); %>
		<input type="radio" name="blinds" id="b-<%= key %>" value="<%= key %>" data-small-blind="<%= cfg.smallBlind %>" data-big-blind="<%= cfg.bigBlind %>">
		<label for="b-<%= key %>"><%= key %></label>
		<% } %>
		<% }); %>
	</div>

	<div class="segment">
		<input type="radio" name="seats" id="s-all" value="" checked>
		<label for="s-all">All</label>
		<% const seatsSeen = new Set(); %>
		<% Object.values(locals.gameConfigs).forEach(cfg => { %>
		<% if (!seatsSeen.has(cfg.maxSeats)) { seatsSeen.add(cfg.maxSeats); %>
		<input type="radio" name="seats" id="s-<%= cfg.maxSeats %>" value="<%= cfg.maxSeats %>-seat" data-max-seats="<%= cfg.maxSeats %>">
		<label for="s-<%= cfg.maxSeats %>"><%= cfg.maxSeats %> seats</label>
		<% } %>
		<% }); %>
	</div>
</div>

<section id="games-list">
	<h3>Games</h3>

	<p>Loading games...</p>

	<!-- xxx filter on the db or the frontend logic? -->
	<template id="game-card-template">
		<div class="game-card">
			<span data-game-id></span>
			<span data-game-players></span>
			<span data-game-blinds></span>
			<span data-game-status></span>
			<form data-join-form method="POST" style="display:inline">
				<button type="submit">Join</button>
			</form>
			<button data-spectate-button type="button">Spectate</button>
		</div>
	</template>
</section>

